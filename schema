-- Clean slate (safe to ignore errors if objects don't exist yet)
DROP TABLE sales CASCADE CONSTRAINTS;
DROP TABLE stock CASCADE CONSTRAINTS;
DROP TABLE medicines CASCADE CONSTRAINTS;
DROP TABLE suppliers CASCADE CONSTRAINTS;

DROP SEQUENCE seq_supplier;
DROP SEQUENCE seq_medicine;
DROP SEQUENCE seq_stock;
DROP SEQUENCE seq_sale;

-- ================================
-- SEQUENCES
-- ================================
CREATE SEQUENCE seq_supplier START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE seq_medicine START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE seq_stock    START WITH 1 INCREMENT BY 1;
CREATE SEQUENCE seq_sale     START WITH 1 INCREMENT BY 1;

-- ================================
-- TABLE: SUPPLIERS
-- ================================
CREATE TABLE suppliers (
    supplier_id   NUMBER PRIMARY KEY,
    supplier_name VARCHAR2(100) NOT NULL,
    phone         VARCHAR2(20),
    email         VARCHAR2(100)
);

-- ================================
-- TABLE: MEDICINES
-- ================================
CREATE TABLE medicines (
    medicine_id   NUMBER PRIMARY KEY,
    medicine_name VARCHAR2(100) NOT NULL,
    category      VARCHAR2(50),
    unit_price    NUMBER(10,2) NOT NULL CHECK (unit_price >= 0),
    supplier_id   NUMBER REFERENCES suppliers(supplier_id),
    expiry_date   DATE
);

-- ================================
-- TABLE: STOCK  (one row per medicine)
-- ================================
CREATE TABLE stock (
    stock_id           NUMBER PRIMARY KEY,
    medicine_id        NUMBER UNIQUE REFERENCES medicines(medicine_id),
    quantity_available  NUMBER DEFAULT 0 CHECK (quantity_available >= 0),
    reorder_level       NUMBER DEFAULT 20,
    last_restock_date   DATE
);

-- ================================
-- TABLE: SALES
-- ================================
CREATE TABLE sales (
    sale_id        NUMBER PRIMARY KEY,
    medicine_id    NUMBER REFERENCES medicines(medicine_id),
    quantity_sold  NUMBER NOT NULL CHECK (quantity_sold > 0),
    sale_date      DATE DEFAULT SYSDATE,
    total_amount   NUMBER(10,2)
);

