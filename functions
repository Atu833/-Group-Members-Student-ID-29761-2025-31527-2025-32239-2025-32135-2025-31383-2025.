SELECT fn_get_unit_price(2) AS amoxicillin_price FROM dual;
SELECT fn_total_revenue(1)  AS paracetamol_revenue FROM dual;
SELECT medicine_id, fn_stock_status(medicine_id) AS status FROM medicines;
